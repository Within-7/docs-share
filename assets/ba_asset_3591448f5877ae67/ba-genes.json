  {
    "type": "Gene",
    "id": "gene_utf8_offset_bug",
    "name": "UTF-8 多字节字符偏移陷阱",
    "category": "pitfall_pattern",
    "description": "UTF-8 编码中中文字符占 3 字节，导致 statSync().size ≠ content.length，使用字节偏移做 checkpoint 会导致 slice 位置错误",
    "methodology": [
      "读取文件时用 content.length 而非 statSync().size 作为字符位置",
      "Checkpoint 记录 content.length（字符数），读取时用 content.slice(position)",
      "验证方法: 对比 Buffer.byteLength() 和 str.length，中文文本差异显著"
    ],
    "applicableScenarios": ["任何涉及中文字符的文本处理", "文件内容增量分割", "Checkpoint 机制实现"],
    "dataRequirements": ["含中文的测试文件", "statSync + readFileSync 对比"],
    "outputFormat": "Bug 修复 + 测试验证",
    "signalsMatch": ["pitfall_pattern", "improvement_opportunity"],
    "tags": ["Bug", "UTF-8", "中文", "Checkpoint"],
    "successRate": 1.0,
    "usageCount": 1,
    "createdAt": "2026-03-26T09:10:00.000Z",
    "updatedAt": "2026-03-26T09:10:00.000Z"
  },
